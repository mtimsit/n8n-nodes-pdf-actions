{
  "name": "n8n-nodes-pdf-actions",
  "version": "0.3.0",
  "description": "Convert images to PDFs or merge images and existing PDFs in n8n.",
  "engines": {
    "node": ">=22.13.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/mtimsit/n8n-nodes-pdf-actions#readme",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Michael Timsit",
    "email": "michael.timsit@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mtimsit/n8n-nodes-pdf-actions.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "npm run build && node --test test/*.test.js",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [],
    "nodes": [
      "dist/nodes/PdfActions/PdfActions.node.js"
    ]
  },
  "dependencies": {
    "@napi-rs/canvas": "1.0.0",
    "image-size": "2.0.2",
    "pdf-lib": "1.17.1",
    "pdf-to-png-converter": "4.1.1",
    "pdfkit": "0.19.1"
  },
  "devDependencies": {
    "@n8n/node-cli": "0.35.1",
    "@types/pdfkit": "^0.17.3",
    "eslint": "9.29.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
